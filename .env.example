# ---------------------------------------------------------------------------
# Car History Viewer — environment variables
# Copy this file to `.env.local` and fill in keys you have. Everything works
# WITHOUT keys (specs + recalls + complaints + photos use free APIs).
# ---------------------------------------------------------------------------

# DEMO_MODE: when true, the paid features (owner history, KM history, plate
# lookup) return realistic SAMPLE data without any key — useful for testing.
# Set to false (or just add real keys below) for live data.
DEMO_MODE=true

# Paid vehicle-history provider (ownership + odometer/KM history).
# Sign up at one of these and paste the key. The adapter in lib/providers.ts
# is wired for VinAudit-style responses — adjust field mapping for others.
#   VinAudit : https://www.vinaudit.com/
#   CarsXE   : https://api.carsxe.com/
#   ClearVIN : https://www.clearvin.com/
HISTORY_API_KEY=

# License plate / car number -> VIN lookup. Enables the "By Car Number" search.
#   CarsXE   : https://api.carsxe.com/   (platedecoder endpoint, adapter pre-wired)
#   Auto.dev : https://www.auto.dev/
PLATE_API_KEY=

# Optional: imagin.studio customer key for high-quality studio car renders.
# Without it, photos fall back to the free carimagery.com API (no key needed).
#   https://www.imagin.studio/
IMAGIN_CUSTOMER=
